<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gauntlet Mode | Alite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #f8fafc; color: #1e293b; overflow-x: hidden; }
        .studio-glass { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 1); box-shadow: 0 20px 50px rgba(0,0,0,0.05); }
        .progress-fill { height: 100%; transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1); background: #0f172a; }
        .choice-btn { transition: all 0.2s ease; border: 2px solid #f1f5f9; }
        .choice-btn:hover { border-color: #0f172a; transform: translateY(-2px); }
        .loading-dots:after { content: '.'; animation: dots 1.5s steps(5, end) infinite; }
        @keyframes dots { 0%, 20% { content: '.'; } 40% { content: '..'; } 60% { content: '...'; } 80%, 100% { content: ''; } }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-6">

    <div class="w-full max-w-xl flex items-center justify-between mb-8">
        <div class="flex flex-col">
            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">Current Session</span>
            <span class="font-bold text-slate-900"><%= user.username %></span>
        </div>
        <div class="flex flex-col items-end">
            <span id="streakDisplay" class="text-[10px] font-black uppercase tracking-widest text-slate-400">Streak: 0</span>
            <span class="font-bold text-slate-900">Gauntlet Mode</span>
        </div>
    </div>

    <div class="w-full max-w-xl h-2 bg-slate-200 rounded-full overflow-hidden mb-12">
        <div id="playerBar" class="progress-fill w-1/2"></div>
    </div>

    <div id="gameCard" class="studio-glass w-full max-w-xl p-10 md:p-14 rounded-[2.5rem] relative">
        <div id="gameUI">
            <h3 id="questionText" class="text-2xl md:text-3xl font-bold text-slate-900 mb-10 leading-tight">
                <span class="loading-dots text-slate-400">Establishing Link</span>
            </h3>

            <div id="optionsContainer" class="grid grid-cols-1 gap-4">
                </div>
        </div>
        
        <p id="feedback" class="absolute bottom-[-40px] left-0 w-full text-center font-bold text-sm uppercase tracking-widest opacity-0 transition-all">
            Correct
        </p>
    </div>

    <script>
        let riddles = [];
        let currentIndex = 0;
        let power = 50;
        let gameActive = false;
        const alphabetMap = { 'A': 0, 'B': 1, 'C': 2, 'D': 3 };

        async function init() {
            try {
                const res = await fetch('/api/gauntlet/start');
                if (!res.ok) throw new Error("Network response error");
                
                const data = await res.json();
                if (!data.success || !data.riddles.length) throw new Error("No data");

                riddles = data.riddles;
                gameActive = true;
                renderRiddle();
                startDrain();
            } catch (err) {
                document.getElementById('questionText').innerHTML = 
                    `<span class="text-red-500 text-lg">System Offline</span><br><span class="text-sm font-normal text-slate-400">Please check your database connection.</span>`;
            }
        }

        function renderRiddle() {
            if (currentIndex >= riddles.length) return triggerVictory();

            const riddle = riddles[currentIndex];
            document.getElementById('questionText').innerText = riddle.question;
            document.getElementById('streakDisplay').innerText = `Streak: ${currentIndex}`;
            
            const container = document.getElementById('optionsContainer');
            container.innerHTML = ''; 

            riddle.options.forEach((text, i) => {
                const btn = document.createElement('button');
                btn.className = "choice-btn flex items-center bg-white p-5 rounded-2xl text-left";
                btn.innerHTML = `
                    <span class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-xs font-black mr-4">${['A','B','C','D'][i]}</span>
                    <span class="font-bold text-slate-700">${text}</span>
                `;
                btn.onclick = () => validate(i);
                container.appendChild(btn);
            });
        }

        function validate(choiceIdx) {
            if (!gameActive) return;

            const correctIdx = alphabetMap[riddles[currentIndex].answer.toUpperCase()];

            if (choiceIdx === correctIdx) {
                flashFeedback("Precise hit", "text-emerald-500");
                adjustPower(15);
                currentIndex++;
                renderRiddle();
            } else {
                flashFeedback("Calculation error", "text-rose-500");
                adjustPower(-20);
            }
        }

        function adjustPower(amt) {
            power = Math.min(100, Math.max(0, power + amt));
            document.getElementById('playerBar').style.width = power + '%';
            if (power <= 0) triggerLoss();
        }

        function startDrain() {
            const timer = setInterval(() => {
                if (!gameActive) return clearInterval(timer);
                adjustPower(-0.3); // Slow background decay
            }, 600);
        }

        function flashFeedback(msg, color) {
            const el = document.getElementById('feedback');
            el.innerText = msg;
            el.className = `absolute bottom-[-40px] left-0 w-full text-center font-bold text-sm uppercase tracking-widest opacity-100 ${color}`;
            setTimeout(() => el.style.opacity = '0', 1000);
        }

        async function triggerVictory() {
            gameActive = false;
            const res = await fetch('/api/gauntlet/win', { method: 'POST' });
            
            document.getElementById('gameCard').innerHTML = `
                <div class="text-center py-6">
                    <div class="text-5xl mb-6">🎯</div>
                    <h2 class="text-3xl font-black text-slate-900 mb-2">Session Complete</h2>
                    <p class="text-slate-500 mb-8 font-medium">Rank updated. +100 Credits earned.</p>
                    <a href="/dashboard" class="bg-slate-900 text-white px-8 py-4 rounded-2xl font-bold inline-block hover:scale-105 transition">Dashboard</a>
                </div>`;
        }

        function triggerLoss() {
            gameActive = false;
            document.getElementById('gameCard').innerHTML = `
                <div class="text-center py-6">
                    <h2 class="text-3xl font-black text-slate-900 mb-2">Power Depleted</h2>
                    <p class="text-slate-500 mb-8 font-medium">The session has timed out.</p>
                    <button onclick="location.reload()" class="bg-slate-100 text-slate-900 px-8 py-4 rounded-2xl font-bold hover:bg-slate-200 transition">Try Again</button>
                </div>`;
        }

        window.onload = init;
    </script>
</body>
</html>
