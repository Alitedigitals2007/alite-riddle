<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gauntlet Mode | Alite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f0f9ff; overflow-x: hidden; }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        .floating-card { animation: float 4s ease-in-out infinite; }

        .option-btn { 
            background: white; border: 2px solid #e2e8f0; border-radius: 1.5rem; 
            padding: 1.25rem; font-weight: 700; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            width: 100%; text-align: left; position: relative;
        }
        .option-btn:hover:not(:disabled) { 
            border-color: #06b6d4; transform: scale(1.02);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        }

        .correct { background: #cffafe !important; border-color: #06b6d4 !important; color: #083344 !important; }
        .wrong { background: #fee2e2 !important; border-color: #ef4444 !important; color: #7f1d1d !important; animation: shake 0.4s; }

        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

        .progress-fill { height: 100%; transition: width 0.4s ease; background: #06b6d4; }
        
        .timer-container { position: absolute; top: 1.5rem; right: 1.5rem; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
        .timer-svg { transform: rotate(-90deg); width: 60px; height: 60px; }
        .timer-circle-prog { 
            fill: none; stroke: #06b6d4; stroke-width: 4; stroke-linecap: round; 
            stroke-dasharray: 176; stroke-dashoffset: 0; transition: stroke-dashoffset 0.5s linear; 
        }

        .xp-toast {
            position: fixed; pointer-events: none; font-weight: 900; font-size: 1.5rem;
            z-index: 100; animation: xpFloat 1s ease-out forwards;
        }
        @keyframes xpFloat {
            0% { transform: translateY(0); opacity: 1; }
            100% { transform: translateY(-100px); opacity: 0; }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <nav class="p-6 flex justify-between items-center max-w-5xl mx-auto w-full">
        <div class="flex flex-col">
            <span class="text-[10px] font-black uppercase text-cyan-600 tracking-widest">Player</span>
            <span class="text-xl font-black text-slate-900"><%= user.username %></span>
        </div>
        <div class="flex flex-col items-center">
            <span id="streakDisplay" class="text-sm font-black text-slate-400">STREAK: 0</span>
            <div id="streakDots" class="flex gap-1 mt-1"></div>
        </div>
        <div class="text-right">
            <span class="text-[10px] font-black uppercase text-slate-400 block">Current XP</span>
            <span id="sessionXp" class="text-xl font-black text-cyan-600 italic">0 XP</span>
        </div>
    </nav>

    <div class="w-full max-w-2xl mx-auto px-6 mb-8">
        <div class="h-3 bg-slate-200 rounded-full overflow-hidden shadow-inner border-2 border-white">
            <div id="playerBar" class="progress-fill w-1/2 shadow-[0_0_15px_rgba(6,182,212,0.5)]"></div>
        </div>
    </div>

    <main class="flex-grow flex items-center justify-center p-6">
        <div id="gameCard" class="max-w-2xl w-full">
            <div class="floating-card bg-white rounded-[2.5rem] p-10 shadow-2xl border border-cyan-50 mb-8 relative">
                <div class="timer-container">
                    <svg class="timer-svg">
                        <circle class="timer-circle-prog" id="powerCircle" cx="30" cy="30" r="28"></circle>
                    </svg>
                </div>
                <h2 id="questionText" class="text-2xl md:text-3xl font-extrabold text-slate-900 leading-tight pr-12">
                    Initializing Link...
                </h2>
            </div>

            <div id="optionsContainer" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
            <div id="feedback" class="mt-8 text-center font-black text-xl h-8"></div>
        </div>
    </main>

    <script>
        let riddles = [];
        let currentIndex = 0;
        let power = 50;
        let totalXp = 0;
        let gameActive = false;
        let isProcessing = false;
        const alphabetMap = ['A', 'B', 'C', 'D'];

        async function init() {
            try {
                const res = await fetch('/api/gauntlet/start');
                const data = await res.json();
                
                console.log("DB Data Check:", data); // Debugging info

                if (!data.success || !data.riddles || data.riddles.length === 0) {
                    throw new Error("No data found");
                }

                riddles = data.riddles;
                gameActive = true;
                renderRiddle();
                startDrain();
            } catch (err) {
                console.error("Init Error:", err);
                document.getElementById('questionText').innerText = "System Offline. Check DB.";
            }
        }

        function renderRiddle() {
            if (currentIndex >= riddles.length) return triggerVictory();

            const riddle = riddles[currentIndex];
            
            // Defensively handle lowercase/uppercase from DB
            const question = riddle.question || riddle.QUESTION;
            document.getElementById('questionText').innerText = question;
            document.getElementById('streakDisplay').innerText = `STREAK: ${currentIndex}`;
            
            // Update Streak Dots
            const dots = document.getElementById('streakDots');
            dots.innerHTML = '';
            riddles.forEach((_, i) => {
                const dot = document.createElement('div');
                dot.className = `w-2 h-2 rounded-full transition-all duration-300 ${i < currentIndex ? 'bg-cyan-500 scale-125 shadow-[0_0_8px_#06b6d4]' : 'bg-slate-300'}`;
                dots.appendChild(dot);
            });

            const container = document.getElementById('optionsContainer');
            container.innerHTML = ''; 

            alphabetMap.forEach((letter) => {
                const btn = document.createElement('button');
                btn.className = "option-btn group";
                
                // Defensive key lookup for option_a, option_b, etc.
                const optionKey = 'option_' + letter.toLowerCase();
                const optionText = riddle[optionKey] || riddle[optionKey.toUpperCase()];

                btn.innerHTML = `
                    <span class="inline-block w-8 h-8 bg-slate-100 rounded-lg text-center leading-8 mr-3 group-hover:bg-cyan-100 group-hover:text-cyan-600 transition font-black">${letter}</span>
                    ${optionText}
                `;
                btn.onclick = (e) => validate(letter, btn, e.clientX, e.clientY);
                container.appendChild(btn);
            });
            isProcessing = false;
        }

        function validate(choice, btn, mouseX, mouseY) {
            if (!gameActive || isProcessing) return;

            const riddle = riddles[currentIndex];
            const correct = (riddle.answer || riddle.ANSWER).toUpperCase();

            if (choice === correct) {
                isProcessing = true;
                btn.classList.add('correct');
                flashFeedback("PRECISION HIT!", "text-cyan-600");
                
                totalXp += 10;
                document.getElementById('sessionXp').innerText = totalXp + " XP";
                showXpPop(10, true, mouseX, mouseY);
                
                adjustPower(15);
                setTimeout(() => {
                    currentIndex++;
                    renderRiddle();
                }, 800);
            } else {
                btn.classList.add('wrong');
                flashFeedback("CORE LEAK!", "text-red-500");
                
                totalXp = Math.max(0, totalXp - 5);
                document.getElementById('sessionXp').innerText = totalXp + " XP";
                showXpPop(-5, false, mouseX, mouseY);
                
                adjustPower(-20);
                btn.disabled = true;
                document.querySelector('.floating-card').animate([
                    { transform: 'translateX(-5px)' }, { transform: 'translateX(5px)' }
                ], { duration: 100, iterations: 4 });
            }
        }

        function adjustPower(amt) {
            power = Math.min(100, Math.max(0, power + amt));
            document.getElementById('playerBar').style.width = power + '%';
            const circle = document.getElementById('powerCircle');
            const circumference = 176;
            circle.style.strokeDashoffset = circumference - (power / 100) * circumference;
            
            if (power <= 0 && gameActive) triggerLoss();
        }

        function startDrain() {
            setInterval(() => { if (gameActive) adjustPower(-0.35); }, 600);
        }

        function flashFeedback(msg, color) {
            const el = document.getElementById('feedback');
            el.innerText = msg;
            el.className = `mt-8 text-center font-black text-xl h-8 ${color} transition-opacity duration-300`;
            setTimeout(() => el.innerText = '', 1000);
        }

        function showXpPop(amount, isPositive, x, y) {
            const toast = document.createElement('div');
            toast.className = `xp-toast ${isPositive ? 'text-cyan-500' : 'text-rose-500'}`;
            toast.style.left = x + 'px';
            toast.style.top = y + 'px';
            toast.innerText = (isPositive ? '+' : '') + amount + ' XP';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 1000);
        }

        async function settleGauntlet(status, xpAmount) {
            try {
                const res = await fetch('/api/gauntlet/settle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ xp: xpAmount, status: status })
                });
                return await res.json();
            } catch (e) {
                console.error("Settlement sync failed", e);
            }
        }

        async function triggerVictory() {
            gameActive = false;
            const bonusXp = Math.floor(power / 5);
            const finalXp = totalXp + bonusXp;

            await settleGauntlet('win', finalXp);

            document.getElementById('gameCard').innerHTML = `
                <div class="bg-white rounded-[3rem] p-12 text-center shadow-2xl border-4 border-cyan-400 floating-card">
                    <div class="text-6xl mb-6">🏆</div>
                    <h2 class="text-4xl font-black text-slate-900 mb-2">GAUNTLET CLEARED</h2>
                    <div class="flex justify-center gap-4 mb-8">
                        <div class="bg-cyan-50 p-4 rounded-2xl">
                            <span class="block text-[10px] uppercase font-black text-cyan-600">Base</span>
                            <span class="text-2xl font-black">${totalXp} XP</span>
                        </div>
                        <div class="bg-amber-50 p-4 rounded-2xl">
                            <span class="block text-[10px] uppercase font-black text-amber-600">Bonus</span>
                            <span class="text-2xl font-black">+${bonusXp} XP</span>
                        </div>
                    </div>
                    <button onclick="window.location.href='/dashboard'" class="bg-cyan-600 text-white px-10 py-4 rounded-2xl font-black hover:scale-105 transition shadow-lg shadow-cyan-200 w-full">
                        COLLECT ${finalXp} XP
                    </button>
                </div>`;
        }

        async function triggerLoss() {
            gameActive = false;
            const salvagedXp = Math.floor(totalXp / 2);
            await settleGauntlet('loss', salvagedXp);

            document.getElementById('gameCard').innerHTML = `
                <div class="bg-white rounded-[3rem] p-12 text-center shadow-2xl border-4 border-red-400">
                    <div class="text-6xl mb-6">💀</div>
                    <h2 class="text-4xl font-black text-red-500 mb-2">DEFEATED</h2>
                    <p class="text-slate-500 mb-8 font-medium italic">Data salvaged: +${salvagedXp} XP</p>
                    <button onclick="location.reload()" class="bg-slate-900 text-white px-10 py-4 rounded-2xl font-black hover:scale-105 transition w-full">
                        REBOOT SESSION
                    </button>
                </div>`;
        }

        window.onload = init;
    </script>
</body>
</html>
