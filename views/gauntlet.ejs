<!DOCTYPE html>
<html lang="en">
<head>
    <title>Gauntlet Mode | Alite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #020617; color: white; overflow: hidden; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .progress-bar { height: 20px; border-radius: 10px; transition: width 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .cyber-glow { box-shadow: 0 0 20px rgba(6, 182, 212, 0.3); }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-4">

    <div class="w-full max-w-2xl mb-8">
        <div class="flex justify-between mb-2 text-[10px] font-black tracking-widest uppercase">
            <span class="text-cyan-400">ALITE (YOU)</span>
            <span class="text-red-500">CYBER-BOSS</span>
        </div>
        <div class="w-full h-6 bg-slate-900 rounded-full overflow-hidden border border-white/10 cyber-glow">
            <div id="playerBar" class="progress-bar bg-gradient-to-r from-cyan-600 to-cyan-400 w-1/2"></div>
        </div>
    </div>

    <div id="gameCard" class="max-w-xl w-full glass p-10 rounded-[3rem] text-center relative">
        <div id="timer" class="absolute top-[-20px] left-1/2 -translate-x-1/2 bg-cyan-500 px-6 py-2 rounded-full font-black text-slate-900 text-sm">
            WAKING UP...
        </div>

        <h3 id="questionText" class="text-2xl font-black mb-8 italic leading-tight">Preparing the Gauntlet...</h3>

        <div class="flex gap-2">
            <input type="text" id="answerInput" placeholder="TYPE YOUR ANSWER..." 
                   class="bg-slate-800 border-none rounded-2xl p-5 w-full font-bold text-center outline-none focus:ring-2 ring-cyan-500">
            <button onclick="checkAnswer()" class="bg-white text-slate-900 px-8 rounded-2xl font-black hover:scale-105 transition">SUBMIT</button>
        </div>
        
        <p id="feedback" class="mt-6 text-xs font-bold uppercase tracking-widest opacity-0">Correct!</p>
    </div>

    <script>
        let riddles = [];
        let currentIndex = 0;
        let power = 50; // Starts at 50%
        let gameActive = false;

        async function startGauntlet() {
            const res = await fetch('/api/gauntlet/start');
            const data = await res.json();
            riddles = data.riddles;
            gameActive = true;
            showRiddle();
            startDrain();
        }

        function showRiddle() {
            if (currentIndex >= riddles.length) {
                endGame(true);
                return;
            }
            document.getElementById('questionText').innerText = riddles[currentIndex].question;
            document.getElementById('answerInput').value = '';
            document.getElementById('answerInput').focus();
        }

        function checkAnswer() {
            if (!gameActive) return;
            const input = document.getElementById('answerInput').value.trim().toLowerCase();
            const correct = riddles[currentIndex].answer.toLowerCase();

            if (input === correct) {
                updatePower(15); // Push bar up
                showFeedback("DOMINATING!", "text-cyan-400");
                currentIndex++;
                showRiddle();
            } else {
                updatePower(-10); // Penalty
                showFeedback("ERROR!", "text-red-500");
            }
        }

        function updatePower(amount) {
            power = Math.min(100, Math.max(0, power + amount));
            document.getElementById('playerBar').style.width = power + '%';
            
            if (power >= 100) endGame(true);
            if (power <= 0) endGame(false);
        }

        function startDrain() {
            const drainInterval = setInterval(() => {
                if (!gameActive) {
                    clearInterval(drainInterval);
                    return;
                }
                updatePower(-0.5); // Constant drain by the Boss
                document.getElementById('timer').innerText = `STREAK: ${currentIndex}`;
            }, 500);
        }

        function showFeedback(text, colorClass) {
            const f = document.getElementById('feedback');
            f.innerText = text;
            f.className = `mt-6 text-xs font-bold uppercase tracking-widest opacity-100 ${colorClass}`;
            setTimeout(() => f.classList.add('opacity-0'), 1000);
        }

        function endGame(won) {
            gameActive = false;
            document.getElementById('gameCard').innerHTML = `
                <h2 class="text-5xl font-black mb-4">${won ? 'VICTORY' : 'DEFEATED'}</h2>
                <p class="text-slate-400 mb-8">${won ? 'The Gauntlet has been conquered.' : 'The Cyber-Boss drained your energy.'}</p>
                <button onclick="location.reload()" class="bg-cyan-500 text-slate-900 px-10 py-4 rounded-2xl font-black">RETRY</button>
            `;
        }

        // Start on load
        window.onload = startGauntlet;
    </script>
</body>
</html>
