<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gauntlet Mode | Alite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f0f9ff; overflow-x: hidden; }
        
        /* Floating Card Animation */
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        .floating-card { animation: float 4s ease-in-out infinite; }

        /* Option Buttons */
        .option-btn { 
            background: white; border: 2px solid #e2e8f0; border-radius: 1.5rem; 
            padding: 1.25rem; font-weight: 700; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            width: 100%; text-align: left; position: relative;
        }
        .option-btn:hover:not(:disabled) { 
            border-color: #06b6d4; transform: scale(1.02);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        }

        /* Result States */
        .correct { background: #cffafe !important; border-color: #06b6d4 !important; color: #083344 !important; }
        .wrong { background: #fee2e2 !important; border-color: #ef4444 !important; color: #7f1d1d !important; animation: shake 0.4s; }

        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

        /* Power Meter (Progress Bar) */
        .progress-fill { height: 100%; transition: width 0.4s ease; background: #06b6d4; }
        
        /* Circular Timer (Gauntlet Decay Visual) */
        .timer-container { position: absolute; top: 1.5rem; right: 1.5rem; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
        .timer-svg { transform: rotate(-90deg); width: 60px; height: 60px; }
        .timer-circle-prog { 
            fill: none; stroke: #06b6d4; stroke-width: 4; stroke-linecap: round; 
            stroke-dasharray: 176; stroke-dashoffset: 0; transition: stroke-dashoffset 0.5s linear; 
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <nav class="p-6 flex justify-between items-center max-w-5xl mx-auto w-full">
        <div class="flex flex-col">
            <span class="text-[10px] font-black uppercase text-cyan-600 tracking-widest">Player</span>
            <span class="text-xl font-black text-slate-900"><%= user.username %></span>
        </div>
        <div class="flex flex-col items-center">
            <span id="streakDisplay" class="text-sm font-black text-slate-400">STREAK: 0</span>
            <div id="streakDots" class="flex gap-1 mt-1">
                </div>
        </div>
        <div class="text-right">
            <span class="text-[10px] font-black uppercase text-slate-400 block">Mode</span>
            <span class="text-xl font-black text-cyan-600 italic">Gauntlet</span>
        </div>
    </nav>

    <div class="w-full max-w-2xl mx-auto px-6 mb-8">
        <div class="h-3 bg-slate-200 rounded-full overflow-hidden shadow-inner">
            <div id="playerBar" class="progress-fill w-1/2"></div>
        </div>
    </div>

    <main class="flex-grow flex items-center justify-center p-6">
        <div id="gameCard" class="max-w-2xl w-full">
            <div class="floating-card bg-white rounded-[2.5rem] p-10 shadow-2xl border border-cyan-50 mb-8 relative">
                <div class="timer-container">
                    <svg class="timer-svg">
                        <circle class="timer-circle-prog" id="powerCircle" cx="30" cy="30" r="28"></circle>
                    </svg>
                </div>
                <h2 id="questionText" class="text-2xl md:text-3xl font-extrabold text-slate-900 leading-tight pr-12">
                    Initializing Link...
                </h2>
            </div>

            <div id="optionsContainer" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                </div>

            <div id="feedback" class="mt-8 text-center font-black text-xl h-8"></div>
        </div>
    </main>

    <script>
        let riddles = [];
        let currentIndex = 0;
        let power = 50;
        let gameActive = false;
        const alphabetMap = ['A', 'B', 'C', 'D'];

        async function init() {
            try {
                const res = await fetch('/api/gauntlet/start');
                const data = await res.json();
                if (!data.success || !data.riddles.length) throw new Error();

                riddles = data.riddles;
                gameActive = true;
                renderRiddle();
                startDrain();
            } catch (err) {
                document.getElementById('questionText').innerText = "System Offline. Check DB.";
            }
        }

        function renderRiddle() {
            if (currentIndex >= riddles.length) return triggerVictory();

            const riddle = riddles[currentIndex];
            document.getElementById('questionText').innerText = riddle.question;
            document.getElementById('streakDisplay').innerText = `STREAK: ${currentIndex}`;
            
            // Update Streak Dots
            const dots = document.getElementById('streakDots');
            dots.innerHTML = '';
            for(let i=0; i<riddles.length; i++) {
                const dot = document.createElement('div');
                dot.className = `w-2 h-2 rounded-full ${i < currentIndex ? 'bg-cyan-500' : 'bg-slate-300'}`;
                dots.appendChild(dot);
            }

            const container = document.getElementById('optionsContainer');
            container.innerHTML = ''; 

            alphabetMap.forEach((letter) => {
                const btn = document.createElement('button');
                btn.className = "option-btn group";
                btn.innerHTML = `
                    <span class="inline-block w-8 h-8 bg-slate-100 rounded-lg text-center leading-8 mr-3 group-hover:bg-cyan-100 group-hover:text-cyan-600 transition">${letter}</span>
                    ${riddle['option_' + letter.toLowerCase()]}
                `;
                btn.onclick = () => validate(letter, btn);
                container.appendChild(btn);
            });
        }

        function validate(choice, btn) {
            if (!gameActive) return;

            const correct = riddles[currentIndex].answer.toUpperCase();
            const allBtns = document.querySelectorAll('.option-btn');

            if (choice === correct) {
                btn.classList.add('correct');
                flashFeedback("CRITICAL HIT!", "text-cyan-600");
                adjustPower(15);
                gameActive = false; // Pause while transitioning
                setTimeout(() => {
                    currentIndex++;
                    gameActive = true;
                    renderRiddle();
                }, 800);
            } else {
                btn.classList.add('wrong');
                flashFeedback("ENERGY DRAINED!", "text-red-500");
                adjustPower(-20);
                // Shake effect
                document.querySelector('.floating-card').classList.add('shake');
                setTimeout(() => document.querySelector('.floating-card').classList.remove('shake'), 400);
            }
        }

        function adjustPower(amt) {
            power = Math.min(100, Math.max(0, power + amt));
            document.getElementById('playerBar').style.width = power + '%';
            
            // Sync circular visual
            const circle = document.getElementById('powerCircle');
            const circumference = 176;
            circle.style.strokeDashoffset = circumference - (power / 100) * circumference;

            if (power <= 0) triggerLoss();
        }

        function startDrain() {
            const timer = setInterval(() => {
                if (!gameActive) return; 
                adjustPower(-0.4); 
            }, 600);
        }

        function flashFeedback(msg, color) {
            const el = document.getElementById('feedback');
            el.innerText = msg;
            el.className = `mt-8 text-center font-black text-xl h-8 ${color}`;
            setTimeout(() => el.innerText = '', 1000);
        }

        function triggerVictory() {
            gameActive = false;
            document.getElementById('gameCard').innerHTML = `
                <div class="bg-white rounded-[3rem] p-12 text-center shadow-2xl border-4 border-cyan-400">
                    <h2 class="text-4xl font-black text-slate-900 mb-4">GAUNTLET CLEARED</h2>
                    <p class="text-slate-500 mb-8">You survived the energy drain. Mastery +100 XP.</p>
                    <a href="/dashboard" class="bg-cyan-600 text-white px-10 py-4 rounded-2xl font-black hover:scale-105 transition inline-block">FINISH SESSION</a>
                </div>`;
        }

        function triggerLoss() {
            gameActive = false;
            document.getElementById('gameCard').innerHTML = `
                <div class="bg-white rounded-[3rem] p-12 text-center shadow-2xl border-4 border-red-400">
                    <h2 class="text-4xl font-black text-red-500 mb-4">DEFEATED</h2>
                    <p class="text-slate-500 mb-8">Your energy reached zero before completion.</p>
                    <button onclick="location.reload()" class="bg-slate-900 text-white px-10 py-4 rounded-2xl font-black hover:scale-105 transition">RETRY GAUNTLET</button>
                </div>`;
        }

        window.onload = init;
    </script>
</body>
</html>
