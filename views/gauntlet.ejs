<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gauntlet Drill | Alite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f0f9ff; overflow: hidden; }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        .floating-card { animation: float 4s ease-in-out infinite; }

        .option-btn { 
            background: white; border: 2px solid #e2e8f0; border-radius: 1.5rem; 
            padding: 1.25rem; font-weight: 700; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            width: 100%; text-align: left; position: relative;
        }
        .option-btn:hover:not(:disabled) { 
            border-color: #06b6d4; transform: scale(1.02);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        }

        .correct { background: #cffafe !important; border-color: #06b6d4 !important; color: #083344 !important; }
        .wrong { background: #fee2e2 !important; border-color: #ef4444 !important; color: #7f1d1d !important; animation: shake 0.4s; }

        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

        .progress-fill { height: 100%; transition: width 0.1s linear; background: #06b6d4; }
        
        .timer-container { position: absolute; top: 1.5rem; right: 1.5rem; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
        .timer-svg { transform: rotate(-90deg); width: 60px; height: 60px; }
        .timer-circle-prog { 
            fill: none; stroke: #06b6d4; stroke-width: 4; stroke-linecap: round; 
            stroke-dasharray: 176; stroke-dashoffset: 0; transition: stroke-dashoffset 0.1s linear; 
        }

        .xp-toast {
            position: fixed; pointer-events: none; font-weight: 900; font-size: 1.5rem;
            z-index: 100; animation: xpFloat 1s ease-out forwards;
        }
        @keyframes xpFloat {
            0% { transform: translateY(0); opacity: 1; }
            100% { transform: translateY(-100px); opacity: 0; }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <nav class="p-6 flex justify-between items-center max-w-5xl mx-auto w-full">
        <div class="flex flex-col">
            <span class="text-[10px] font-black uppercase text-cyan-600 tracking-widest">Player</span>
            <span class="text-xl font-black text-slate-900"><%= user.username %></span>
        </div>
        <div class="flex flex-col items-center">
            <span id="streakDisplay" class="text-sm font-black text-slate-400 italic">SOLVED: 0</span>
        </div>
        <div class="text-right">
            <span class="text-[10px] font-black uppercase text-slate-400 block">Session Earnings</span>
            <span id="sessionXp" class="text-xl font-black text-cyan-600 italic">0 XP</span>
        </div>
    </nav>

    <div class="w-full max-w-2xl mx-auto px-6 mb-8">
        <div class="h-3 bg-slate-200 rounded-full overflow-hidden shadow-inner border-2 border-white">
            <div id="playerBar" class="progress-fill w-full shadow-[0_0_15px_rgba(6,182,212,0.5)]"></div>
        </div>
    </div>

    <main class="flex-grow flex items-center justify-center p-6">
        <div id="gameCard" class="max-w-2xl w-full">
            <div class="floating-card bg-white rounded-[2.5rem] p-10 shadow-2xl border border-cyan-50 mb-8 relative">
                <div class="timer-container">
                    <svg class="timer-svg">
                        <circle class="timer-circle-prog" id="powerCircle" cx="30" cy="30" r="28"></circle>
                    </svg>
                </div>
                <h2 id="questionText" class="text-2xl md:text-3xl font-extrabold text-slate-900 leading-tight pr-12">
                    Establishing DB Link...
                </h2>
            </div>

            <div id="optionsContainer" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
            <div id="feedback" class="mt-8 text-center font-black text-xl h-8"></div>
        </div>
    </main>

    <script>
        let riddles = [];
        let currentIndex = 0;
        let totalXp = 0;
        let gameActive = false;
        let timeLeft = 45; // 45 Second Drill
        let timerInterval;
        const alphabetMap = ['A', 'B', 'C', 'D'];

        async function init() {
            try {
                const res = await fetch('/api/gauntlet/start');
                const data = await res.json();
                
                if (!data.success || !data.riddles || data.riddles.length === 0) throw new Error();

                riddles = data.riddles;
                gameActive = true;
                renderRiddle();
                startDrillTimer();
            } catch (err) {
                document.getElementById('questionText').innerText = "System Offline. Check DB.";
            }
        }

        function startDrillTimer() {
            const totalDuration = 45;
            timerInterval = setInterval(() => {
                if (!gameActive) return;

                timeLeft -= 0.1;
                const percentage = (timeLeft / totalDuration) * 100;

                // Update Progress Bar
                document.getElementById('playerBar').style.width = percentage + '%';
                
                // Update Circular Timer
                const circle = document.getElementById('powerCircle');
                const circumference = 176;
                circle.style.strokeDashoffset = circumference - (percentage / 100) * circumference;

                if (timeLeft <= 0) {
                    endDrill();
                }
            }, 100);
        }

        function renderRiddle() {
            if (currentIndex >= riddles.length) return endDrill();

            const riddle = riddles[currentIndex];
            const question = riddle.question || riddle.QUESTION;
            document.getElementById('questionText').innerText = question;
            document.getElementById('streakDisplay').innerText = `SOLVED: ${currentIndex}`;

            const container = document.getElementById('optionsContainer');
            container.innerHTML = ''; 

            alphabetMap.forEach((letter) => {
                const btn = document.createElement('button');
                btn.className = "option-btn group";
                const optionKey = 'option_' + letter.toLowerCase();
                const optionText = riddle[optionKey] || riddle[optionKey.toUpperCase()];

                btn.innerHTML = `
                    <span class="inline-block w-8 h-8 bg-slate-100 rounded-lg text-center leading-8 mr-3 group-hover:bg-cyan-100 group-hover:text-cyan-600 transition font-black">${letter}</span>
                    ${optionText}
                `;
                btn.onclick = (e) => validate(letter, btn, e.clientX, e.clientY);
                container.appendChild(btn);
            });
        }

        function validate(choice, btn, mouseX, mouseY) {
            if (!gameActive) return;
            const correct = (riddles[currentIndex].answer || riddles[currentIndex].ANSWER).toUpperCase();

            if (choice === correct) {
                btn.classList.add('correct');
                flashFeedback("PRECISION HIT!", "text-cyan-600");
                
                totalXp += 10;
                document.getElementById('sessionXp').innerText = totalXp + " XP";
                showXpPop(10, true, mouseX, mouseY);
                
                currentIndex++;
                setTimeout(renderRiddle, 300);
            } else {
                btn.classList.add('wrong');
                flashFeedback("CORE LEAK!", "text-red-500");
                // In 45s drill, wrong answers just slow you down, no time reduction requested.
            }
        }

        function flashFeedback(msg, color) {
            const el = document.getElementById('feedback');
            el.innerText = msg;
            el.className = `mt-8 text-center font-black text-xl h-8 ${color} transition-opacity duration-300`;
            setTimeout(() => el.innerText = '', 800);
        }

        function showXpPop(amount, isPositive, x, y) {
            const toast = document.createElement('div');
            toast.className = `xp-toast ${isPositive ? 'text-cyan-500' : 'text-rose-500'}`;
            toast.style.left = x + 'px';
            toast.style.top = y + 'px';
            toast.innerText = '+' + amount + ' XP';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 1000);
        }

        async function endDrill() {
            gameActive = false;
            clearInterval(timerInterval);

            // POST to backend to add XP to the user total
            await fetch('/api/gauntlet/settle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ xp: totalXp })
            });

            document.getElementById('gameCard').innerHTML = `
                <div class="bg-white rounded-[3rem] p-12 text-center shadow-2xl border-4 border-cyan-400 floating-card">
                    <div class="text-6xl mb-6">⏰</div>
                    <h2 class="text-4xl font-black text-slate-900 mb-2">DRILL OVER</h2>
                    <p class="text-slate-500 mb-8 font-medium italic">Total session earnings: +${totalXp} XP</p>
                    <button onclick="window.location.href='/dashboard'" class="bg-cyan-600 text-white px-10 py-4 rounded-2xl font-black hover:scale-105 transition shadow-lg shadow-cyan-200 w-full">
                        RETURN TO DASHBOARD
                    </button>
                </div>`;
        }

        window.onload = init;
    </script>
</body>
</html>
