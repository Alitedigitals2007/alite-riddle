<!DOCTYPE html>
<html lang="en">
<head>
    <title>Hall of Fame | Alite Riddles</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f0f9ff; }
        .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.5); }
        .top-three { transition: transform 0.3s ease; }
        .top-three:hover { transform: translateY(-10px); }
    </style>
</head>
<body class="pb-20">

    <nav class="max-w-4xl mx-auto p-8 flex justify-between items-center">
        <a href="/dashboard" class="text-slate-500 font-bold hover:text-cyan-600 transition">← Dashboard</a>
        <h1 class="text-xl font-black tracking-widest text-slate-900 uppercase">Leaderboard</h1>
        <div class="w-10"></div> </nav>

    <main class="max-w-4xl mx-auto px-6">
        
        <div class="grid grid-cols-3 gap-4 items-end mb-12 mt-8">
            <% if(leaders[1]) { %>
            <div class="top-three flex flex-col items-center">
                <div class="w-16 h-16 rounded-2xl bg-slate-200 border-4 border-white shadow-lg flex items-center justify-center font-black text-2xl text-slate-500 mb-2">
                    <%= leaders[1].username.charAt(0).toUpperCase() %>
                </div>
                <div class="w-full glass-card rounded-t-2xl p-4 text-center h-24 border-b-0">
                    <p class="font-black text-slate-700 truncate text-sm"><%= leaders[1].username %></p>
                    <p class="text-cyan-600 font-black">LVL <%= leaders[1].current_level %></p>
                    <span class="text-[10px] font-bold text-slate-400">2ND</span>
                </div>
            </div>
            <% } %>

            <% if(leaders[0]) { %>
            <div class="top-three flex flex-col items-center">
                <div class="relative">
                    <div class="absolute -top-6 left-1/2 -translate-x-1/2 text-3xl">👑</div>
                    <div class="w-24 h-24 rounded-[2rem] bg-cyan-500 border-4 border-white shadow-2xl flex items-center justify-center font-black text-4xl text-white mb-2 shadow-cyan-200">
                        <%= leaders[0].username.charAt(0).toUpperCase() %>
                    </div>
                </div>
                <div class="w-full glass-card rounded-t-3xl p-6 text-center h-40 shadow-xl border-b-0 border-cyan-100">
                    <p class="font-black text-slate-900 truncate text-lg"><%= leaders[0].username %></p>
                    <p class="text-cyan-600 font-black text-2xl">LVL <%= leaders[0].current_level %></p>
                    <span class="bg-cyan-100 text-cyan-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest">Champion</span>
                </div>
            </div>
            <% } %>

            <% if(leaders[2]) { %>
            <div class="top-three flex flex-col items-center">
                <div class="w-16 h-16 rounded-2xl bg-orange-100 border-4 border-white shadow-lg flex items-center justify-center font-black text-2xl text-orange-600 mb-2">
                    <%= leaders[2].username.charAt(0).toUpperCase() %>
                </div>
                <div class="w-full glass-card rounded-t-2xl p-4 text-center h-20 border-b-0">
                    <p class="font-black text-slate-700 truncate text-sm"><%= leaders[2].username %></p>
                    <p class="text-cyan-600 font-black">LVL <%= leaders[2].current_level %></p>
                    <span class="text-[10px] font-bold text-slate-400">3RD</span>
                </div>
            </div>
            <% } %>
        </div>

        <div class="bg-white rounded-[2.5rem] shadow-xl border border-slate-100 overflow-hidden">
            <div class="p-6 border-b border-slate-50 flex justify-between items-center bg-slate-50/50">
                <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Global Ranking</span>
                <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Progress</span>
            </div>

            <div class="divide-y divide-slate-50">
                <% leaders.slice(3).forEach((leader, index) => { %>
                    <div class="flex justify-between items-center p-6 hover:bg-cyan-50/30 transition group">
                        <div class="flex items-center gap-4">
                            <span class="font-black text-slate-300 w-8">#<%= index + 4 %></span>
                            <div class="h-10 w-10 rounded-xl bg-slate-100 flex items-center justify-center font-bold text-slate-500 group-hover:bg-white transition">
                                <%= leader.username.charAt(0).toUpperCase() %>
                            </div>
                            <div>
                                <span class="font-bold text-slate-900"><%= leader.username %></span>
                                <% if(leader.username === user.username) { %>
                                    <span class="ml-2 text-[8px] bg-cyan-600 text-white px-2 py-0.5 rounded-full font-black uppercase">You</span>
                                <% } %>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="font-black text-slate-900">LVL <%= leader.current_level %></span>
                            <p class="text-[10px] font-bold text-slate-400 uppercase"><%= leader.points %> XP</p>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <% if(userRank > 50) { %>
        <div class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-4xl bg-slate-900 text-white p-6 rounded-[2rem] shadow-2xl flex justify-between items-center border border-slate-700">
            <div class="flex items-center gap-4">
                <span class="font-black text-cyan-400">#<%= userRank %></span>
                <span class="font-bold"><%= user.username %> (You)</span>
            </div>
            <span class="font-black text-cyan-400">LVL <%= user.current_level %></span>
        </div>
        <% } %>

    </main>

</body>
</html>