<!DOCTYPE html>
<html lang="en">
<head>
    <title>Solo Mode | Alite Riddles</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f0f9ff; overflow-x: hidden; }
        
        /* Floating Animation */
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        .floating-card { animation: float 4s ease-in-out infinite; }

        /* Option Buttons */
        .option-btn { 
            background: white; border: 2px solid #e2e8f0; border-radius: 1.5rem; 
            padding: 1.5rem; font-weight: 700; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            width: 100%; text-align: left; position: relative; overflow: hidden;
        }
        .option-btn:hover:not(:disabled) { 
            border-color: #06b6d4; transform: scale(1.02);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        /* Result States */
        .correct { background: #cffafe !important; border-color: #06b6d4 !important; color: #083344 !important; animation: pulse-cyan 0.5s ease-in-out; }
        .wrong { background: #fee2e2 !important; border-color: #ef4444 !important; color: #7f1d1d !important; animation: shake 0.4s; }

        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }
        @keyframes pulse-cyan { 0% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.7); } 70% { box-shadow: 0 0 0 15px rgba(6, 182, 212, 0); } 100% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0); } }

        /* CIRCULAR CLOCK CSS */
        .timer-container { position: absolute; top: 1.5rem; right: 1.5rem; width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; }
        .timer-svg { transform: rotate(-90deg); width: 80px; height: 80px; }
        .timer-circle-bg { fill: none; stroke: #f1f5f9; stroke-width: 6; }
        .timer-circle-prog { 
            fill: none; stroke: #06b6d4; stroke-width: 6; stroke-linecap: round; 
            stroke-dasharray: 226; stroke-dashoffset: 0; transition: stroke-dashoffset 1s linear, stroke 0.3s; 
        }
        #timerText { position: absolute; font-weight: 900; font-size: 1.5rem; color: #0f172a; transition: all 0.3s; }
        .timer-danger { stroke: #ef4444 !important; }
        .text-danger { color: #ef4444 !important; animation: heartBeat 0.5s infinite; }
        @keyframes heartBeat { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <nav class="p-6 flex justify-between items-center max-w-5xl mx-auto w-full">
        <a href="/level-map" class="bg-white/50 backdrop-blur-md px-4 py-2 rounded-xl text-slate-500 font-bold hover:text-cyan-600 transition">← Map</a>
        <div class="flex flex-col items-center">
            <span class="text-[10px] font-black uppercase text-cyan-600 tracking-widest">Question <%= qNumber %> / 10</span>
            <div class="flex gap-1.5 mt-2">
                <% for(let i=0; i<10; i++) { %>
                    <div class="w-3 h-3 rounded-full transition-all duration-500 <%= i < qNumber ? 'bg-cyan-500 scale-110 shadow-lg shadow-cyan-200' : 'bg-slate-300' %>"></div>
                <% } %>
            </div>
        </div>
        <div class="text-right">
            <span class="text-[10px] font-black uppercase text-slate-400 block">Level</span>
            <span class="text-2xl font-black text-cyan-600"><%= user.current_level %></span>
        </div>
    </nav>

    <main class="flex-grow flex items-center justify-center p-6">
        <div class="max-w-2xl w-full text-center">
            
            <div id="gameBox" class="floating-card bg-white rounded-[3rem] p-12 shadow-2xl border border-cyan-50 mb-10 relative overflow-hidden">
                <div class="timer-container">
                    <svg class="timer-svg">
                        <circle class="timer-circle-bg" cx="40" cy="40" r="36"></circle>
                        <circle id="timerCircle" class="timer-circle-prog" cx="40" cy="40" r="36"></circle>
                    </svg>
                    <div id="timerText">15</div>
                </div>
                <h2 class="text-3xl font-extrabold text-slate-900 leading-tight pr-20 text-left relative z-10"><%= riddle.question %></h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <% ['A', 'B', 'C', 'D'].forEach(letter => { %>
                    <button onclick="checkAnswer('<%= letter %>', this)" class="option-btn group" data-choice="<%= letter %>">
                        <span class="inline-block w-8 h-8 bg-slate-100 rounded-lg text-center leading-8 mr-3 group-hover:bg-cyan-100 group-hover:text-cyan-600 transition"><%= letter %></span>
                        <%= riddle['option_' + letter.toLowerCase()] %>
                    </button>
                <% }) %>
            </div>

            <div id="feedback" class="mt-10 text-center font-black text-2xl h-12 flex items-center justify-center"></div>
            
            <button id="nextBtn" onclick="location.reload()" class="hidden mt-4 w-full bg-cyan-600 text-white py-6 rounded-[2rem] font-black uppercase tracking-widest hover:bg-cyan-500 shadow-[0_10px_0_0_#0891b2] active:shadow-none active:translate-y-2 transition-all">
                Continue →
            </button>
        </div>
    </main>

    <script>
        // --- SOUND ENGINE ---
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playSound(type) {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            
            if(type === 'correct') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5
                osc.frequency.exponentialRampToValueAtTime(880, audioCtx.currentTime + 0.1); // A5
                gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
            } else if(type === 'wrong') {
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(220, audioCtx.currentTime); // A3
                osc.frequency.linearRampToValueAtTime(110, audioCtx.currentTime + 0.2);
                gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
                gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.2);
                osc.start(); osc.stop(audioCtx.currentTime + 0.2);
            } else if(type === 'tick') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(1500, audioCtx.currentTime);
                gain.gain.setValueAtTime(0.02, audioCtx.currentTime);
                gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.05);
                osc.start(); osc.stop(audioCtx.currentTime + 0.05);
            }
        }

        // --- TIMER LOGIC ---
        let timeLeft = 15;
        const totalTime = 15;
        const circumference = 226;
        let isActive = true;

        const timer = setInterval(() => {
            if (!isActive) return clearInterval(timer);
            timeLeft--;
            
            const timerText = document.getElementById('timerText');
            const circle = document.getElementById('timerCircle');
            
            timerText.innerText = timeLeft;
            circle.style.strokeDashoffset = circumference - (timeLeft / totalTime) * circumference;

            if (timeLeft <= 5) {
                circle.classList.add('timer-danger');
                timerText.classList.add('text-danger');
                playSound('tick');
            }

            if (timeLeft <= 0) handleFinish("TIME EXPIRED!");
        }, 1000);

        async function checkAnswer(choice, btn) {
            if (!isActive) return;
            isActive = false;
            document.querySelectorAll('.option-btn').forEach(b => b.disabled = true);

            try {
                const res = await fetch('/check-answer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ riddleId: '<%= riddle.id %>', selectedOption: choice })
                });
                const data = await res.json();

                document.querySelectorAll('.option-btn').forEach(b => {
                    if(b.getAttribute('data-choice') === data.correctLetter) b.classList.add('correct');
                });

                if (data.success) {
                    playSound('correct');
                    document.getElementById('feedback').innerHTML = "<span class='text-cyan-600'>✨ EXCELLENT! ✨</span>";
                } else {
                    playSound('wrong');
                    btn.classList.add('wrong');
                    document.getElementById('feedback').innerHTML = "<span class='text-rose-500'>Ouch! Wrong.</span>";
                }

                if (data.levelUp) {
                    document.getElementById('feedback').innerHTML = "<span class='text-cyan-700 animate-bounce'>🏆 LEVEL UNLOCKED!</span>";
                    document.getElementById('nextBtn').innerText = "PROCEED TO NEXT LEVEL";
                }

            } catch (e) {
                document.getElementById('feedback').innerText = "Connection lost!";
            } finally {
                document.getElementById('nextBtn').classList.remove('hidden');
            }
        }

        function handleFinish(msg) {
            isActive = false;
            playSound('wrong');
            document.getElementById('feedback').innerHTML = `<span class='text-rose-500'>${msg}</span>`;
            document.getElementById('nextBtn').classList.remove('hidden');
            document.querySelectorAll('.option-btn').forEach(b => b.disabled = true);
        }
    </script>
</body>
</html>